{
  "name": "@dhlavaty/react-frontend-template",
  "version": "0.0.1",
  "main": "index.js",
  "license": "MIT",
  "scripts": {
    "serve": "webpack-dev-server",
    "prepr": "rimraf dist",
    "prettier:check": "prettier -l '**/*.{ts,tsx,js,jsx,json,md,html,htm}'",
    "prettier": "prettier --write '**/*.{ts,tsx,js,jsx,json,md,html,htm}'",
    "pr": "yarn run prettier:check && tsc --noEmit && webpack",
    "prf": "yarn run prettier && yarn run pr"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-loader": "^10.1.1",
    "html-webpack-plugin": "^5.6.6",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "author": "Dusan Hlavaty <dhlavaty@gmail.com>"
}
